# OurTextScores environment configuration — copy to .env and fill in real values.
# .env is gitignored; this example is committed. Do NOT put real secrets here.

# ─────────────────────────────────────────────────────────────────────────────
# Auth (NextAuth)
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=            # required: `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
AUTH_ALLOW_EMAIL_ACCOUNT_LINKING=false
AUTH_BOOTSTRAP_ADMIN_EMAILS=   # comma-separated admin emails granted on first sign-in
AUTH_BOOTSTRAP_EMAILS=         # comma-separated allowlisted emails
BETA_PREVIEW_ADMIN_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Public URLs
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:4000/api
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000
PUBLIC_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SCORE_EDITOR_URL=http://localhost:3000/score-editor

# ─────────────────────────────────────────────────────────────────────────────
# Score Editor API integration
# The embedded editor calls /api/score-editor/* which the frontend forwards to
# the score_editor_api service (bound to 127.0.0.1 only).
# ─────────────────────────────────────────────────────────────────────────────
SCORE_EDITOR_API_ORIGIN=http://score_editor_api:3000
NEXT_PUBLIC_SCORE_EDITOR_API_BASE=/api/score-editor
# Shared app token. The frontend music proxy injects this as x-ots-api-token and
# the editor API enforces it (OTS_API_AUTH_TOKEN). REQUIRED whenever a server-side
# HF token is set below, or OMR / NotaGen-space routes return 403/401.
# Generate: `openssl rand -hex 32`. Same value must be set on both services.
SCORE_EDITOR_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Editor API — server-credential hardening flags
#   ALLOW_SERVER_LLM_KEYS: allow the editor API to fall back to its own HF/LLM
#     credentials. When 1, SCORE_EDITOR_API_TOKEN MUST be set.
#   ALLOW_UNAUTHENTICATED_LLM_PROXY: keep the /api/llm/* user-key proxy usable
#     without the app token (it only relays the caller's own key; rate-limited).
# ─────────────────────────────────────────────────────────────────────────────
ALLOW_SERVER_LLM_KEYS=1
ALLOW_UNAUTHENTICATED_LLM_PROXY=1

# Server-side Hugging Face space tokens (leave blank to require user-supplied tokens)
MUSIC_TRANSCODA_SPACE_TOKEN=
MUSIC_NOTAGEN_SPACE_TOKEN=
MUSIC_NOTAGEN_DEFAULT_SPACE_ID=jhlusko/NotaGen-Space

# Production editor API image (used with docker-compose.score-editor-image.yml)
OTS_EDITOR_API_IMAGE=ghcr.io/ourtextscores/ots-web-editor-api
OTS_EDITOR_API_IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://ots:change_me@mongo:27017/ourtextscores?authSource=admin
MONGO_INITDB_ROOT_USERNAME=ots
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_AUTO_INDEX=true

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (object storage)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_RAW_BUCKET=raw-scores
MINIO_DERIVATIVES_BUCKET=derivatives
MINIO_AUX_BUCKET=aux

# ─────────────────────────────────────────────────────────────────────────────
# Meilisearch
# ─────────────────────────────────────────────────────────────────────────────
MEILI_HOST=http://meili:7700
MEILI_MASTER_KEY=meili_master_key

# ─────────────────────────────────────────────────────────────────────────────
# Email (NextAuth magic links + notifications)
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_SERVER=smtp://mailpit:1025
EMAIL_FROM=no-reply@ourtextscores.com
LEGAL_CONTACT_EMAIL=
LEGAL_EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Fossil (version control backend for scores)
# ─────────────────────────────────────────────────────────────────────────────
FOSSIL_PATH=/data/fossil_data
FOSSIL_USER=ots

# ─────────────────────────────────────────────────────────────────────────────
# Music tooling (backend + editor API) — defaults are usually fine
# ─────────────────────────────────────────────────────────────────────────────
MUSESCORE_CLI=musescore4
MUSESCORE_PDF_MODE=async
MUSESCORE_EXPORT_TIMEOUT_MS=0
MUSESCORE_WRAPPER_TIMEOUT_SECONDS=0
KERN_CONVERTER_CLI=krn2musicxml
KERN_CONVERTER_TIMEOUT_MS=60000
ABC_CONVERTER_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────────────────────
# OpenTelemetry (optional)
# ─────────────────────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ourtextscores-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
SCORE_EDITOR_OTEL_ENABLED=false
SCORE_EDITOR_OTEL_SERVICE_NAME=ots-web-score-editor-api
